# Frontend Environment Configuration
# Copy this file to .env and fill in values from CDK deployment outputs (outputs.json)
#
# After running: cdk deploy --all --outputs-file outputs.json
# Extract values with:
#   API_URL      = LifeInsuranceApiStack.ApiUrl
#   USER_POOL_ID = LifeInsuranceInfraStack.UserPoolId
#   CLIENT_ID    = LifeInsuranceInfraStack.UserPoolClientId

VITE_API_URL=https://<YOUR_API_GATEWAY_ID>.execute-api.<YOUR_REGION>.amazonaws.com/prod
VITE_AWS_REGION=us-east-1
VITE_USER_POOL_ID=<YOUR_COGNITO_USER_POOL_ID>
VITE_USER_POOL_CLIENT_ID=<YOUR_COGNITO_USER_POOL_CLIENT_ID>
